# PostgreSQL (např. Neon z Vercel Marketplace). Lokálně: docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/it_prace_evidence?schema=public"

# Volitelné (session je ověřovaná v DB; můžete nechat prázdné)
AUTH_SECRET=""

# Vercel Blob (Storage → vytvořit store → proměnná BLOB_READ_WRITE_TOKEN se doplní při propojení).
# Na Vercelu povinné pro nahrávání příloh. Lokálně volitelné — bez tokenu se ukládá do uploads/
BLOB_READ_WRITE_TOKEN=""
